      "type": "string"
    },
    "address_line_2": {
      "type": "string"
    },
    "phone_number_1": {
      "type": "string"
    },
    "phone_number_2": {
      "type": "string"
    },
    "mobile_number_1": {
      "type": "string"
    },
    "mobile_number_2": {
      "type": "string"
    },
    "email_1": {
      "type": "string"
    },
    "email_2": {
      "type": "string"
    },
    "std_code": {
      "type": "string"
    },
    "anniversary_date": {
      "type": "date"
    },
    "gender": {
      "type": "enumeration",
      "enum": [
        "Male",
        "Female"
      ]
    },
    "resignation_date": {
      "type": "date"
    },
    "description": {
      "type": "richtext"
    },
    "designation": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::designation.designation"
