      "type": "decimal",
      "default": 0
    },
    "tds": {
      "type": "decimal",
      "default": 0
    },
    "esi": {
      "type": "decimal",
      "default": 0
    },
    "pf": {
      "type": "decimal",
      "default": 0
    },
    "advanced_loan": {
      "type": "decimal",
      "default": 0
    },
    "other_deduction": {
      "type": "decimal",
      "default": 0
