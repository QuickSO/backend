{
  "kind": "collectionType",
  "collectionName": "employee_documents",
  "info": {
    "singularName": "employee-document",
    "pluralName": "employee-documents",
    "displayName": "Employee Document",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "uid": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "document_no": {
      "type": "string"
    },
    "description": {
      "type": "richtext"
    },
    "creator": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "front_side": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "back_side": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "employee": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::employee.employee"
    },
    "document": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::document.document"
    }
  }
}
