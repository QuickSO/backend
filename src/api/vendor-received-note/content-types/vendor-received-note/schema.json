    "corrective_actions": {
      "type": "decimal",
      "default": 0
    },
    "prompt_reply": {
      "type": "decimal",
      "default": 0
    },
    "delivery_quality": {
      "type": "decimal",
      "default": 0
    },
    "quality_systems": {
      "type": "decimal",
      "default": 0
