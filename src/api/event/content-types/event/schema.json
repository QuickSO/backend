{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "uid": {
      "type": "string"
    },
    "creator": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "no": {
      "type": "string"
    },
    "members": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::employee.employee"
    },
    "url": {
      "type": "string"
    },
    "time": {
      "type": "datetime"
    },
    "status": {
      "type": "enumeration",
      "enum": ["Planned", "Rescheduled", "Cancelled", "Done"],
      "default": "Planned"
    },
    "description": {
      "type": "richtext"
    },
    "is_deleted": {
      "type": "boolean",
      "default": false
    }
  }
}
