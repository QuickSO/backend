{
  "kind": "collectionType",
  "collectionName": "app_emails",
  "info": {
    "singularName": "app-email",
    "pluralName": "app-emails",
    "displayName": "App Email",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "content": {
      "type": "richtext"
    },
    "uid": {
      "type": "string"
    },
    "creator": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "status": {
      "type": "enumeration",
      "enum": ["Draft", "Sent", "Archived", "Deleted"],
      "default": "Draft"
    },
    "attachment": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images", "files", "videos", "audios"]
    },
    "sender": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::employee.employee"
    },
    "parent": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::app-email.app-email"
    },
    "recipients": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::employee.employee"
    },
    "cc_recipients": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::employee.employee"
    },
    "bcc_recipients": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::employee.employee"
    },
    "is_deleted": {
      "type": "boolean",
      "default": false
    },
    "subject": {
      "type": "string"
    },
    "is_read": {
      "type": "boolean",
      "default": false
    }
  }
}
