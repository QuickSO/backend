{
  "kind": "collectionType",
  "collectionName": "meeting_comments",
  "info": {
    "singularName": "meeting-comment",
    "pluralName": "meeting-comments",
    "displayName": "Meeting Comment"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "content": {
      "type": "richtext"
    },
    "creator": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "attachment": {
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ],
      "type": "media",
      "multiple": false
    },
    "employee": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::employee.employee"
    },
    "uid": {
      "type": "string"
    },
    "meeting": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::meeting.meeting"
    }
  }
}
