{
  "kind": "collectionType",
  "collectionName": "task_documents",
  "info": {
    "singularName": "task-document",
    "pluralName": "task-documents",
    "displayName": "Task Document",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "uid": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "richtext"
    },
    "attachment": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images", "files", "videos", "audios"]
    },
    "task": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::task.task"
    },
    "creator": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "is_deleted": {
      "type": "boolean",
      "default": false
    }
  }
}
