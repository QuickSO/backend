{
  "kind": "collectionType",
  "collectionName": "daily_reports",
  "info": {
    "singularName": "daily-report",
    "pluralName": "daily-reports",
    "displayName": "Daily Report",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "date": {
      "type": "date"
    },
    "uid": {
      "type": "string",
      "required": true,
      "unique": false
    },
    "creator": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "employee": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::employee.employee"
    },
    "tasks": {
      "type": "json"
    },
    "issues": {
      "type": "json"
    },
    "details": {
      "type": "richtext"
    },
    "attached_photo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "is_deleted": {
      "type": "boolean",
      "default": false
    },
    "timesheet": {
      "type": "string"
    },
    "project": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::project.project"
    }
  }
}
