{
  "kind": "collectionType",
  "collectionName": "task_materials",
  "info": {
    "singularName": "task-material",
    "pluralName": "task-materials",
    "displayName": "Task Material",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "uid": {
      "type": "string"
    },
    "creator": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "task": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::task.task"
    },
    "material_item": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::material-item.material-item"
    },
    "amount": {
      "type": "decimal"
    },
    "description": {
      "type": "richtext"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "Pending",
        "Approved",
        "Rejected",
        "Requested",
        "In Progress",
        "Done"
      ],
      "default": "Pending"
    },
    "quantity": {
      "type": "decimal"
    },
    "material_group": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::material-group.material-group"
    },
    "material_unit": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::material-unit.material-unit"
    },
    "is_deleted": {
      "type": "boolean",
      "default": false
    },
    "approved_by": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::employee.employee"
    },
    "approved_at": {
      "type": "datetime"
    },
    "employee": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::employee.employee"
    }
  }
}
