{
  "kind": "collectionType",
  "collectionName": "agency_debit_notes",
  "info": {
    "singularName": "agency-debit-note",
    "pluralName": "agency-debit-notes",
    "displayName": "Agency Debit Note",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "heading": {
      "type": "string"
    },
    "no": {
      "type": "string"
    },
    "uid": {
      "type": "string"
    },
    "creator": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "attachment": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "employee": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::employee.employee"
    },
    "remarks": {
      "type": "richtext"
    },
    "description": {
      "type": "richtext"
    },
    "grand_total": {
      "type": "decimal"
    },
    "project": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::project.project"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "Pending",
        "Approved"
      ],
      "default": "Pending"
    },
    "approved_by": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::employee.employee"
    },
    "approved_at": {
      "type": "datetime"
    },
    "agency": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::agency.agency"
    },
    "creation_employee": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::employee.employee"
    },
    "work_order": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::agency-quotation.agency-quotation"
    }
  }
}
