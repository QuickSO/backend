{
  "kind": "collectionType",
  "collectionName": "extra_works",
  "info": {
    "singularName": "extra-work",
    "pluralName": "extra-works",
    "displayName": "Extra Work"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "no": {
      "type": "string"
    },
    "uid": {
      "type": "string"
    },
    "creator": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "employee": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::employee.employee"
    },
    "description": {
      "type": "richtext"
    },
    "remarks": {
      "type": "richtext"
    },
    "grand_total": {
      "type": "decimal"
    },
    "approved_by": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::employee.employee"
    },
    "job_title": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::job-title.job-title"
    },
    "attachment": {
      "allowedTypes": ["images", "files", "videos", "audios"],
      "type": "media",
      "multiple": false
    },
    "project": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::project.project"
    },
    "status": {
      "type": "enumeration",
      "enum": ["Pending", "Approved"],
      "default": "Pending"
    },
    "provider_uid": {
      "type": "string"
    },
    "provider_type": {
      "type": "enumeration",
      "enum": ["Vendor", "Sub-contractor", "Agency"]
    },
    "approved_at": {
      "type": "datetime"
    },
    "creation_employee": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::employee.employee"
    }
  }
}
