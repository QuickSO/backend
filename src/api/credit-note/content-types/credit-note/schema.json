{
  "kind": "collectionType",
  "collectionName": "credit_notes",
  "info": {
    "singularName": "credit-note",
    "pluralName": "credit-notes",
    "displayName": "Credit Note",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "no": {
      "type": "string"
    },
    "uid": {
      "type": "string"
    },
    "creator": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "remarks": {
      "type": "richtext"
    },
    "description": {
      "type": "richtext"
    },
    "grand_total": {
      "type": "decimal"
    },
    "employee": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::employee.employee"
    },
    "attachment": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images", "files", "videos", "audios"]
    },
    "project": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::project.project"
    },
    "status": {
      "type": "enumeration",
      "enum": ["Pending", "Approved"],
      "default": "Pending"
    },
    "approved_by": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::employee.employee"
    },
    "provider_uid": {
      "type": "string"
    },
    "provider_type": {
      "type": "enumeration",
      "enum": ["Vendor", "Sub-contractor", "Agency"]
    },
    "approved_at": {
      "type": "datetime"
    },
    "agency": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::agency.agency"
    },
    "vendor": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::vendor.vendor"
    },
    "sub_contractor": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::sub-contractor.sub-contractor"
    },
    "creation_employee": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::employee.employee"
    }
  }
}
